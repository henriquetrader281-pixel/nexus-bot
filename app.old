import streamlit as st
import arsenal, trends, update, radar_engine, estudio, postador
import mineracao as miny
import google.generativeai as genai
import json, os
from datetime import datetime

st.set_page_config(page_title="Nexus Absolute V101", layout="wide", page_icon="🔱")

def renderizar_card_produto(idx, nome, valor, calor, ticket, link, mkt_alvo):
    icones = {"Shopee": "🧡", "Mercado Livre": "💛", "Amazon": "💙"}
    with st.container(border=True):
        c1, c2, c3 = st.columns([2, 1, 1])
        with c1:
            n_f = nome.replace("*", "").strip() if nome else "Produto Detectado"
            st.markdown(f"**{icones.get(mkt_alvo, '🛍️')} {n_f}**")
            st.caption(f"💰 {valor} | 🎫 {ticket}")
        with c2:
            c_num = "".join(filter(str.isdigit, str(calor)))
            calor_num = min(max(int(c_num), 0), 100) if c_num else 0
            st.progress(calor_num / 100)
            st.write(f"🌡️ {calor_num}°C")
        if c3.button("🎯 Selecionar", key=f"sel_{idx}_{mkt_alvo}", use_container_width=True):
            st.session_state.sel_nome = n_f
            st.session_state.sel_link = link
            update.registrar_mineracao(n_f, link, calor_num)
            st.toast(f"Selecionado: {n_f}")

if "autenticado" not in st.session_state: st.session_state.autenticado = False
# ... (lógica de login aqui) ...

if "motor_ia_obj" not in st.session_state:
    genai.configure(api_key=st.secrets["GEMINI_API_KEY"])
    st.session_state.motor_ia_obj = genai.GenerativeModel('gemini-1.5-flash')

st.sidebar.title("🔱 Nexus Control")
mkt_global = st.sidebar.selectbox("Marketplace:", ["Shopee", "Mercado Livre", "Amazon"])
st.session_state.mkt_global = mkt_global

tabs = st.tabs(["🔍 SCANNER", "🚀 ARSENAL", "📈 TRENDS", "🎥 ESTÚDIO", "🛰️ POSTADOR", "📊 DASHBOARD"])

with tabs[0]:
    col1, col2 = st.columns([1, 2])
    qtd = col1.selectbox("Volume:", [15, 30, 45])
    foco_nicho = col2.text_input("🎯 Nicho:", value="Cozinha Criativa", key="foco_nicho")
    
    if st.button("🔥 INICIAR VARREDURA", use_container_width=True):
        prompt = f"Sem introdução. Liste {qtd} produtos de {mkt_global} para '{foco_nicho}'. Formato: NOME: [nome] | CALOR: [75-99] | VALOR: R$ [valor] | TICKET: [Baixo] | URL: [link]"
        st.session_state.res_busca = miny.minerar_produtos(prompt, mkt_global, "groq")

    if st.session_state.get("res_busca"):
        for idx, linha in enumerate(st.session_state.res_busca.split('\n')):
            linha_limpa = linha.replace("**", "").strip()
            if "|" in linha_limpa:
                try:
                    partes = [p.strip() for p in linha_limpa.split('|')]
                    dados = {p.split(':')[0].strip().upper(): p.split(':')[1].strip() for p in partes if ':' in p}
                    # Lógica de Nome Blindada (Busca por chave ou posição)
                    n_f = dados.get("NOME")
                    if not n_f:
                        for k in dados.keys():
                            if "NOME" in k: n_f = dados[k]; break
                    if not n_f: n_f = partes[0].split(':')[-1].strip() if ':' in partes[0] else partes[0]
                    
                    renderizar_card_produto(idx, n_f, dados.get("VALOR", "---"), dados.get("CALOR", "0"), "Médio", dados.get("URL", "#"), mkt_global)
                except: continue

with tabs[1]: arsenal.exibir_arsenal(miny, st.session_state.motor_ia_obj)
with tabs[3]: estudio.exibir_estudio(miny, "groq")
